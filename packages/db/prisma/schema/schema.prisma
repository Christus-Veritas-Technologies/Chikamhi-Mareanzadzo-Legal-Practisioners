generator client {
  provider = "prisma-client"
  output   = "../generated"
  moduleFormat = "esm"
  runtime = "bun"
}

datasource db {
  provider = "postgresql"
}

// Two roles only. Attorneys can do everything a Paralegal can, plus: manage staff accounts
// (Users & Roles is an attorney-only page), view the firm-wide Audit Log, and delete
// clients/cases/folders/tags. The old ADMIN role was folded into ATTORNEY — every ADMIN
// account becomes ATTORNEY (see the migration that narrows this enum).
enum StaffRole {
  ATTORNEY
  PARALEGAL
}

enum ClientType {
  CORPORATE
  DECEASED_ESTATE
  FAMILY
  GOVERNMENT
}

enum CaseStatus {
  ACTIVE
  UNDER_REVIEW
  CLOSED
}

enum DocumentStatus {
  DRAFT
  UNDER_REVIEW
  FILED
  SIGNED
  EXECUTED
}

enum AuditAction {
  VIEWED
  UPLOADED
  SIGNED
  FILED
  MOVED
  DELETED
  RESTORED
  OCR_COMPLETED
  CASE_OPENED
}

enum NotificationType {
  CASE_UPLOAD
  CASE_STATUS_CHANGE
  OCR_COMPLETE
  DEADLINE_SET
  DOCUMENT_SIGNED
}

enum DocumentOcrStatus {
  NOT_APPLICABLE
  PENDING
  PROCESSING
  DONE
  FAILED
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  username     String    @unique
  passwordHash String
  passwordSalt String
  role         StaffRole @default(PARALEGAL)
  isActive     Boolean   @default(true)
  lastActiveAt DateTime?
  avatarKey    String? // Cloudflare R2 object key for the profile photo
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Notification preferences — real, persisted settings even though not every underlying
  // event (e.g. OCR) is actually implemented yet.
  notifyOnCaseUpload   Boolean @default(true)
  notifyOnOcrComplete  Boolean @default(true)
  notifyWeeklyDigest   Boolean @default(false)

  clientsAsAttorney Client[]        @relation("ClientAttorneyOfRecord")
  casesAsLead       Case[]          @relation("CaseLeadAttorney")
  documentsUploaded Document[]      @relation("DocumentUploadedBy")
  documentsDeleted  Document[]      @relation("DocumentDeletedBy")
  auditEntries      AuditLogEntry[] @relation("AuditActor")
  notifications     Notification[]  @relation("UserNotifications")
  deadlinesCreated  Deadline[]      @relation("DeadlineCreatedBy")
  documentsSigned   DocumentSignature[] @relation("DocumentSignedBy")
  clientsDeleted    Client[]        @relation("ClientDeletedBy")
  casesDeleted      Case[]          @relation("CaseDeletedBy")
  foldersDeleted    Folder[]        @relation("FolderDeletedBy")
  tagsDeleted       Tag[]           @relation("TagDeletedBy")

  @@map("users")
}

model Client {
  id                 String     @id @default(cuid())
  name               String
  type               ClientType
  regNumber          String?
  attorneyOfRecordId String?
  attorneyOfRecord   User?      @relation("ClientAttorneyOfRecord", fields: [attorneyOfRecordId], references: [id])
  clientSince        DateTime   @default(now())
  deletedAt          DateTime?
  deletedById        String?
  deletedBy          User?      @relation("ClientDeletedBy", fields: [deletedById], references: [id])
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  cases     Case[]
  documents Document[]
  contacts  Contact[]

  @@map("clients")
}

model Contact {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name      String
  role      String?
  email     String?
  phone     String?
  createdAt DateTime @default(now())

  @@map("contacts")
}

model Case {
  id             String     @id @default(cuid())
  caseNumber     String     @unique
  title          String
  clientId       String
  client         Client     @relation(fields: [clientId], references: [id])
  status         CaseStatus @default(ACTIVE)
  matterType     String
  location       String?
  leadAttorneyId String?
  leadAttorney   User?      @relation("CaseLeadAttorney", fields: [leadAttorneyId], references: [id])
  registry       String?
  openedAt       DateTime   @default(now())
  closedAt       DateTime?
  deletedAt      DateTime?
  deletedById    String?
  deletedBy      User?      @relation("CaseDeletedBy", fields: [deletedById], references: [id])
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  documents     Document[]
  auditEntries  AuditLogEntry[]
  notifications Notification[]
  deadlines     Deadline[]

  @@map("cases")
}

// A case's key dates — filing deadlines, hearing dates, statutory time limits. Read-model
// only: "overdue" is computed client-side (dueAt < now && !completedAt), no cron/scheduler
// exists in this app to push day-of reminders — the lead attorney gets a one-time in-app
// notification when the deadline is first created.
model Deadline {
  id            String    @id @default(cuid())
  caseId        String
  case          Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  title         String
  dueAt         DateTime
  notes         String?
  completedAt   DateTime?
  createdById   String
  createdBy     User      @relation("DeadlineCreatedBy", fields: [createdById], references: [id])
  createdAt     DateTime  @default(now())

  @@index([caseId, dueAt])
  @@map("deadlines")
}

model Folder {
  id          String      @id @default(cuid())
  name        String      @unique
  deletedAt   DateTime?
  deletedById String?
  deletedBy   User?       @relation("FolderDeletedBy", fields: [deletedById], references: [id])
  createdAt   DateTime    @default(now())
  documents   Document[]
  tags        FolderTag[]

  @@map("folders")
}

model Tag {
  id          String        @id @default(cuid())
  name        String        @unique
  colorClass  String        @default("bg-muted-foreground")
  deletedAt   DateTime?
  deletedById String?
  deletedBy   User?         @relation("TagDeletedBy", fields: [deletedById], references: [id])
  createdAt   DateTime      @default(now())
  documents   DocumentTag[]
  folders     FolderTag[]

  @@map("tags")
}

// A folder can carry multiple tags (e.g. "Conveyancing" + "Bulawayo") — separate from
// DocumentTag, which tags individual documents.
model FolderTag {
  folderId String
  folder   Folder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  tagId    String
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([folderId, tagId])
  @@map("folder_tags")
}

model Document {
  id           String         @id @default(cuid())
  name         String
  fileType     String
  status       DocumentStatus @default(DRAFT)
  storageKey   String? // Cloudflare R2 object key — nullable until real upload is wired
  sizeBytes    Int?
  clientId     String
  client       Client         @relation(fields: [clientId], references: [id])
  caseId       String?
  case         Case?          @relation(fields: [caseId], references: [id])
  folderId     String?
  folder       Folder?        @relation(fields: [folderId], references: [id])
  uploadedById String
  uploadedBy   User           @relation("DocumentUploadedBy", fields: [uploadedById], references: [id])
  deletedAt    DateTime?
  deletedById  String?
  deletedBy    User?          @relation("DocumentDeletedBy", fields: [deletedById], references: [id])
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  // OCR — runs (via tesseract.js, server-side) after an image document's bytes land in R2.
  // ocrText is also matched by the documents search filter, making scans full-text searchable.
  ocrStatus      DocumentOcrStatus @default(NOT_APPLICABLE)
  ocrText        String?
  ocrCompletedAt DateTime?

  tags          DocumentTag[]
  auditEntries  AuditLogEntry[]
  notifications Notification[]
  signatures    DocumentSignature[]

  @@map("documents")
}

// A typed-name electronic signature (name + role + explicit consent attestation + timestamp
// + IP), not a drawn/wet-ink signature — the same mechanism most e-signature tools offer
// alongside drawn signatures, chosen here to avoid a canvas/gesture dependency on both
// platforms. A document can carry multiple signatures (client, witness, attorney, etc.).
model DocumentSignature {
  id           String    @id @default(cuid())
  documentId   String
  document     Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  signerName   String
  signerRole   String?
  signedById   String?
  signedBy     User?     @relation("DocumentSignedBy", fields: [signedById], references: [id])
  ipAddress    String?
  consentText  String
  createdAt    DateTime  @default(now())

  @@map("document_signatures")
}

model DocumentTag {
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  tagId      String
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([documentId, tagId])
  @@map("document_tags")
}

// Doubles as both the firm-wide Audit Log and each Case's activity timeline
// (the timeline is just this table filtered by caseId).
model AuditLogEntry {
  id          String      @id @default(cuid())
  actorId     String?
  actor       User?       @relation("AuditActor", fields: [actorId], references: [id])
  action      AuditAction
  targetLabel String
  documentId  String?
  document    Document?   @relation(fields: [documentId], references: [id])
  caseId      String?
  case        Case?       @relation(fields: [caseId], references: [id])
  sourceIp    String?
  createdAt   DateTime    @default(now())

  @@map("audit_log_entries")
}

// In-app notifications only (no email/push delivery yet) — surfaced via the bell dropdown
// on web and native. Created by server-side triggers: case-upload and case-status-change.
model Notification {
  id         String           @id @default(cuid())
  userId     String
  user       User             @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  type       NotificationType
  title      String
  body       String
  caseId     String?
  case       Case?            @relation(fields: [caseId], references: [id])
  documentId String?
  document   Document?        @relation(fields: [documentId], references: [id])
  readAt     DateTime?
  createdAt  DateTime         @default(now())

  @@index([userId, readAt])
  @@map("notifications")
}
